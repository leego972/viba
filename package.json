{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.13.0 <23",
    "pnpm": ">=10.24.0 <11"
  },
  "scripts": {
    "build": "pnpm run build:render",
    "build:render": "pnpm --filter @workspace/bridge-ai run build && pnpm --filter @workspace/api-server run build && node scripts/verify-render-output.mjs",
    "start": "node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "start:render": "node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck:full": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "typecheck": "pnpm run typecheck:full"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@types/libsodium-wrappers": "^0.8.2",
    "libsodium-wrappers": "^0.8.4",
    "stripe": "20.0.0",
    "stripe-replit-sync": "1.0.0"
  }
}
