{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "browser:install": "node -e \"import('child_process').then(({execSync})=>{try{execSync('npx playwright install chromium --with-deps',{stdio:'inherit'})}catch(e){console.log('Playwright install skipped (not in PATH or CI):',e.message)}})\"",
    "browser:check": "node -e \"import('child_process').then(({execSync})=>{try{const v=execSync('npx playwright --version 2>&1').toString().trim();console.log(JSON.stringify({chromium:'ok',version:v}))}catch{console.log(JSON.stringify({chromium:'unavailable',note:'Playwright not installed — browser jobs use user-guided sessions'}))}})\"",
    "railway:cli-check": "node -e \"import('child_process').then(({execSync})=>{try{const v=execSync('railway --version 2>&1').toString().trim();console.log(JSON.stringify({available:true,version:v}))}catch{console.log(JSON.stringify({available:false,version:null}))}})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@axe-core/playwright": "^4.10.2",
    "@sentry/node": "^10.58.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "chrome-launcher": "^1.2.0",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "lighthouse": "^12.8.2",
    "nodemailer": "^8.0.9",
    "openai": "^4.103.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "stripe": "^17.7.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "catalog:",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.3",
    "esbuild": "0.28.1",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.1",
    "supertest": "^7.1.0",
    "thread-stream": "3.1.0",
    "vitest": "^4.1.6"
  }
}
