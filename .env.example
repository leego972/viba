# =============================================================================
  #  VIBA — Environment Variables Reference
  #  Copy this file to .env and fill in real values. NEVER commit .env.
  # =============================================================================
  #
  #  LEGEND
  #  [required]  Server will refuse to start without this.
  #  [required*] Required only when the related feature is enabled.
  #  [optional]  Safe to omit; a documented default is used.
  #  [auto]      Set by the platform (Railway / Replit). Do not set manually.
  #  [server]    Never sent to the browser.
  #  [settings]  Can also be set via the admin /config panel (DB takes priority).
  #
  # =============================================================================

  # ── Database ──────────────────────────────────────────────────────────────────
  # [required] [server]
  # Full PostgreSQL connection string.
  # Railway: copy from the "Variables" tab of your Postgres plugin.
  DATABASE_URL=postgresql://user:password@host:5432/dbname

  # ── Server ────────────────────────────────────────────────────────────────────
  # [auto] [server]
  # Bound port. Set automatically by Railway and Replit. Do not set manually.
  # PORT=5000

  # [required] [server]
  # Random secret for signing express-session cookies.
  # Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
  SESSION_SECRET=replace_with_64_char_random_hex

  # ── Access Control ────────────────────────────────────────────────────────────
  # [optional] [server]
  # Static bearer token for the legacy single-token access gate.
  # When set, every /api request must include:  Authorization: Bearer <token>
  # Leave unset to operate in open mode (use Stripe subscriptions instead).
  ACCESS_TOKEN=

  # [required] [server]
  # Bearer token protecting the /api/admin/* endpoints.
  # Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
  # Without this the admin panel returns 503.
  ADMIN_TOKEN=replace_with_64_char_random_hex

  # [optional] [server]
  # Shared secret between VIBA and Archibald Titan AI (embedded at /bridge).
  # When present, requests from Archibald skip subscriber access checks.
  # Must match VIBA_BYPASS_TOKEN in the Archibald environment.
  ARCHIBALD_BYPASS_TOKEN=

  # ── Public URL ────────────────────────────────────────────────────────────────
  # [optional] [server]
  # Public-facing HTTPS base URL. Used in outgoing emails (access token links).
  # Default: https://viba.guru
  VIBA_PUBLIC_URL=https://viba.guru

  # ── AI Provider API Keys ──────────────────────────────────────────────────────
  # All provider keys are optional.
  # Without a key, that provider runs in simulation (mock) mode — useful for
  # development and demos without spending API credits.
  # Keys can also be stored via the admin /config panel (DB value takes priority).

  # [optional] [server] [settings]
  # OpenAI — ChatGPT provider.
  # Create at: https://platform.openai.com/api-keys
  OPENAI_API_KEY=sk-...

  # [optional] [server] [settings]
  # Anthropic — Claude provider.
  # Create at: https://console.anthropic.com/settings/keys
  ANTHROPIC_API_KEY=sk-ant-...

  # [optional] [server] [settings]
  # Google — Gemini provider.  NOTE: the var is GEMINI_API_KEY, NOT GOOGLE_API_KEY.
  # Create at: https://aistudio.google.com/app/apikey
  GEMINI_API_KEY=AIza...

  # [optional] [server] [settings]
  # Perplexity — research and web-search provider.
  # Create at: https://www.perplexity.ai/settings/api
  PERPLEXITY_API_KEY=pplx-...

  # [optional] [server] [settings]
  # Replit agent provider.
  REPLIT_API_KEY=

  # [optional] [server] [settings]
  # Manus agent provider.
  MANUS_API_KEY=

  # ── AI Model Overrides ────────────────────────────────────────────────────────
  # Override the default model for each provider.
  # These can also be changed via the admin /config panel.

  # [optional] [server] [settings]  Default: gpt-4.1-mini
  # OPENAI_MODEL=gpt-4.1-mini

  # [optional] [server] [settings]  Default: claude-sonnet-4-5
  # ANTHROPIC_MODEL=claude-sonnet-4-5

  # [optional] [server] [settings]  Default: gemini-2.0-flash
  # GEMINI_MODEL=gemini-2.0-flash

  # [optional] [server] [settings]  Default: sonar
  # PERPLEXITY_MODEL=sonar

  # ── Stripe Payments ───────────────────────────────────────────────────────────
  # All Stripe variables are optional as a group.
  # When STRIPE_SECRET_KEY is absent, the /pricing page shows a "coming soon"
  # state and the access gate falls back to ACCESS_TOKEN mode.
  # All four must be set together to enable live subscriptions.

  # [required*] [server]
  # Stripe secret API key.  Use sk_test_... for development, sk_live_... for prod.
  # Dashboard: https://dashboard.stripe.com/apikeys
  STRIPE_SECRET_KEY=sk_test_...

  # [required*] [server]
  # Stripe publishable key. Sent to the browser via /api/stripe/config (not via env).
  # Dashboard: https://dashboard.stripe.com/apikeys
  STRIPE_PUBLISHABLE_KEY=pk_test_...

  # [required*] [server]
  # Stripe recurring Price ID for the $50/month subscription.
  # Create the product + price in the Stripe dashboard, then paste the price_ ID here.
  # Dashboard: https://dashboard.stripe.com/products
  STRIPE_PRICE_ID=price_...

  # [required*] [server]
  # Stripe webhook signing secret. Verifies that webhook events come from Stripe.
  # Create a webhook at https://dashboard.stripe.com/webhooks pointing to:
  #   https://viba.guru/api/stripe/webhook
  # Events to enable: checkout.session.completed, customer.subscription.updated,
  #   customer.subscription.deleted, invoice.payment_failed, invoice.payment_succeeded
  STRIPE_WEBHOOK_SECRET=whsec_...

  # ── Email (SMTP) ──────────────────────────────────────────────────────────────
  # Used to deliver the access token to new subscribers after checkout.
  # All SMTP variables are optional as a group.
  # When absent, token delivery is logged as a warning and skipped (no email sent).

  # [required*] [server]
  # SMTP server hostname.  Examples: smtp.sendgrid.net  smtp.mailgun.org
  SMTP_HOST=smtp.sendgrid.net

  # [optional] [server]  Default: 587
  # SMTP_PORT=587

  # [required*] [server]
  # SMTP authentication username (often your full email or an API key username).
  SMTP_USER=apikey

  # [required*] [server]
  # SMTP authentication password or API key.
  SMTP_PASS=SG.replace_with_sendgrid_api_key

  # [optional] [server]
  # From address shown in outgoing emails. Defaults to SMTP_USER if unset.
  SMTP_FROM=noreply@viba.guru

  # ── Circuit Breaker ───────────────────────────────────────────────────────────
  # Controls automatic fallback-to-simulation when a provider is repeatedly failing.
  # State is persisted in the DB so it survives server restarts.

  # [optional] [server]  Default: 5
  # Consecutive failures before a provider circuit opens (trips to simulation mode).
  # CIRCUIT_OPEN_THRESHOLD=5

  # [optional] [server]  Default: 300000 (5 minutes)
  # Milliseconds the circuit stays open before a half-open probe is allowed.
  # CIRCUIT_TIMEOUT_MS=300000

  # ── Runtime ───────────────────────────────────────────────────────────────────
  # [auto]  Set to "production" by Railway. Controls logging format and error detail.
  # NODE_ENV=production
  