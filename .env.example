# =============================================================================
# VIBA — production environment reference
# Copy to a private environment only. Never commit real values.
# =============================================================================

# ── Required core services ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
SESSION_SECRET=replace_with_at_least_64_random_hex_characters
NODE_ENV=production
PUBLIC_ORIGIN=https://viba.guru
PUBLIC_SITE_URL=https://viba.guru

# Render sets PORT automatically.
# PORT=10000

# ── Persistent user project storage ───────────────────────────────────────────
# REQUIRED in production. This must be inside the mounted Render persistent disk.
# render.yaml mounts the disk at /var/data.
VIBA_PROJECT_STORAGE_ROOT=/var/data/viba-projects

# Never enable this in production. Missing/failed AI providers must fail honestly.
ALLOW_SIMULATION_MODE=false

# ── Administrator access ──────────────────────────────────────────────────────
# Session-based owner admins are matched against this comma-separated list.
VIBA_ADMIN_EMAILS=owner@example.com

# Dedicated admin-console bearer token. Generate at least 32 random bytes.
ADMIN_TOKEN=replace_with_at_least_64_random_hex_characters

# Optional legacy API-wide bearer gate. Prefer normal user sessions.
ACCESS_TOKEN=

# Optional read-only Bridge embed secret.
ARCHIBALD_BYPASS_TOKEN=

# ── Browser security ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://viba.guru,https://www.viba.guru
FRAME_ANCESTORS=https://viba.guru,https://www.viba.guru
CROSS_SITE_COOKIES=false

# ── Platform AI keys (optional) ───────────────────────────────────────────────
# Customer keys belong in each user's encrypted VIBA Vault. Platform keys below
# are server-only fallbacks and must be configured in Render, never plaintext DB.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
VENICE_API_KEY=

OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GEMINI_MODEL=gemini-2.0-flash
PERPLEXITY_MODEL=sonar
MISTRAL_MODEL=mistral-large-latest
DEEPSEEK_MODEL=deepseek-chat
GROQ_MODEL=llama-3.3-70b-versatile
VENICE_MODEL=llama-3.3-70b

# User-supplied self-hosted/custom endpoints are stored as account preferences.
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2
CUSTOM_ENDPOINT=
CUSTOM_API_KEY=
CUSTOM_MODEL=

# ── Per-user encrypted vault ──────────────────────────────────────────────────
# REQUIRED when using the VIBA Vault. Use a stable 32-byte key encoded as hex or
# base64 according to vibaVault.ts. Rotating it without migration loses access.
VIBA_VAULT_MASTER_KEY=

# GitHub access is per user and must be saved in the encrypted Vault.
# Do not set a shared GITHUB_TOKEN for customer repository operations.

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_value
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_value
STRIPE_PRICE_ID=price_value
STRIPE_WEBHOOK_SECRET=whsec_value

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@viba.guru

# ── Optional external services ────────────────────────────────────────────────
RENDER_API_KEY=
VAST_AI_API_KEY=
ELEVENLABS_API_KEY=
SENTRY_DSN=

# ── Runtime controls ──────────────────────────────────────────────────────────
CIRCUIT_OPEN_THRESHOLD=5
CIRCUIT_TIMEOUT_MS=300000
FALLBACK_ALERT_THRESHOLD=3
FALLBACK_ALERT_ENABLED=true
